    "linkedin:auto-apply": "node automation/linkedin-agent.mjs --apply --submit --interval 5",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "playwright": "^1.54.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "firebase-tools": "^15.22.4"
  }
}
