{
  "name": "job-application-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "automate:apply": "node automation/apply-with-playwright.mjs",
    "linkedin:login": "node automation/linkedin-agent.mjs --login --keepOpen",
